{
  "[markdown]": {
    "files.trimTrailingWhitespace": false
  },
  "editor.formatOnSave": true,
  "editor.rulers": [100],
  "files.encoding": "utf8",
  "files.eol": "\n",
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,
  "better-comments.tags": [
    {
      "tag": "#", // white 見出し
      "color": "#f92672",
      "bold": true
    },
    {
      "tag": "~", // 打消し線
      "strikethrough": true
    },
    {
      "tag": ":", // 太字
      "bold": true
    },
    {
      "tag": "!", // red is-danger
      "color": "#ff3860"
    },
    {
      "tag": "?", // blue is-info
      "color": "#209cee"
    },
    {
      "tag": "@", // yellow is-warning
      "color": "#ffdd57"
    },
    {
      "tag": "+", // green is-success
      "color": "#23d160"
    }
  ]
}
